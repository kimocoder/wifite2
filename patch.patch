+        return f'{hps} H/s'
+
+    @staticmethod
+    def _format_duration(seconds):
+        if seconds >= 3600:
+            return f'{seconds / 3600:.1f}h'
+        if seconds >= 60:
+            return f'{seconds / 60:.1f}m'
+        return f'{int(seconds)}s'
